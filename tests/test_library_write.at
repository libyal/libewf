m4_include([package.m4])
m4_include([test_macros.at])

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running library write tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([library write])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

dnl Runs write tests with one or more test binaries.
dnl Arguments:
dnl   skip_condition
dnl   test_names
m4_define([RUN_WRITE_TEST_BINARIES],
  [m4_ifblank([$2], [m4_fatal([Missing test names])])

  m4_foreach_w(
    [test_name],
    [$2],
    [m4_define(
      [test_binary],
      [m4_expand(test_prefix[]_test_[]test_name)])dnl

    m4_foreach_w(
      [media_size],
      [0 1474560],
      [m4_foreach_w(
        [maximum_segment_size],
        [0 368640],
        [dnl Compression levels: none (n), empty-block (e), fast (f), best (b).
        m4_foreach_w(
          [compression_level],
          [n e f b],
          [m4_define([write_options], [-B[]media_size -c[]compression_level -S[]maximum_segment_size])

          AT_SETUP(test_binary write_options)

          AT_SKIP_IF(
            [test -n "${]$1[}"])

          AT_CHECK(ath_fn_run_test_binary test_binary write_options output)

          AT_CLEANUP]
        )]
      )]
    )]
  )]
)

SETUP_HELPER_FUNCTIONS

RUN_WRITE_TEST_BINARIES(
  [SKIP_LIBRARY_TESTS],
  [write write_chunk])
