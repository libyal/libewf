dnl Runs ewfexport and compares resulting files against a reference
dnl Arguments:
dnl   test_profile
dnl   test_options
dnl   test_inputs
m4_define([RUN_TEST_EWFEXPORT_AND_COMPARE_FILES],
  [m4_foreach_w(
    [test_input],
    [$3],
    [m4_define([option_set], m4_normalize(get_test_input_value([test_input], 1)))
    m4_define([test_options], m4_normalize(get_test_input_value([test_input], 2)))
    m4_define([test_file], [_strip(get_test_input_value([test_input], 3))])

    m4_ifblank(option_set, m4_define([option_set], [.]))

    m4_define([sanitized_test_file],
      [m4_translit([test_file], [[],[],[]"'`\], [______])])

    m4_define([ewfexport_options], m4_normalize($2 test_options))

    m4_ifblank(
      ewfexport_options,
      [m4_define(
        [test_description],
        [ewfexport with input: 'sanitized_test_file'])],
      [m4_define(
        [test_description],
        [ewfexport with options: ']ewfexport_options[' and input: 'sanitized_test_file'])])

    AT_SETUP(test_description)

    AT_SKIP_IF(
      [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

    AT_SKIP_IF([test -z "${GZIP_COMMAND}"])
    AT_SKIP_IF([test -z "${SED}"])
    AT_SKIP_IF([test -z "${ZCAT}"])

    TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/test_file"`

    AT_CHECK(ath_fn_run_ewfexport_and_compare_files $1 "option_set" ewfexport_options "${TEST_FILE}")

    AT_CLEANUP])
  ])

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running tools tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([tools])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS

RUN_TEST_BINARIES(
  [SKIP_TOOLS_TESTS],
  [tools_bodyfile tools_byte_size_string tools_device_handle tools_digest_hash tools_export_handle tools_guid tools_imaging_handle tools_info_handle tools_log_handle tools_mount_path_string tools_output tools_path_string tools_platform tools_signal tools_storage_media_buffer tools_system_string tools_verification_handle])

RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
  [ewfinfo],
  [ewfinfo],
  [],
  test_inputs_ewfinfo)

RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
  [ewfinfo],
  [ewfinfo_logical],
  [],
  test_inputs_ewfinfo_logical)

RUN_TEST_EWFTOOL_AND_COMPARE_BODYFILE(
  [ewfinfo],
  [ewfinfo_logical_bodyfile],
  test_inputs_ewfinfo_logical_bodyfile)

m4_if(
  [HAVE_MULTI_THREAD_SUPPORT],
  [1],
  [dnl Test with:
  dnl * single-threaded with buffered reads (-j0)
  dnl * single-threaded with data chunk reads (-j0 -x)
  dnl * multi-threaded with buffered reads (-j4)
  dnl * multi-threaded with data chunk reads (-j4 -x)
  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
    [ewfverify],
    [ewfverify],
    [-j0 -q],
    test_inputs_ewfverify)

  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
    [ewfverify],
    [ewfverify],
    [-j0 -q -x],
    test_inputs_ewfverify)

  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
    [ewfverify],
    [ewfverify],
    [-j4 -q],
    test_inputs_ewfverify)

  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
    [ewfverify],
    [ewfverify],
    [-j4 -q -x],
    test_inputs_ewfverify)],

  [dnl Test with:
  dnl * with buffered reads
  dnl * with data chunk reads (-x)
  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
    [ewfverify],
    [ewfverify],
    [-q],
    test_inputs_ewfverify)

  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
    [ewfverify],
    [ewfverify],
    [-q -x],
    test_inputs_ewfverify)
  ])

m4_if(
  [HAVE_MULTI_THREAD_SUPPORT],
  [1],
  [dnl Test with:
  dnl * single-threaded with buffered reads (-j0)
  dnl * single-threaded with data chunk reads (-j0 -x)
  dnl * multi-threaded with buffered reads (-j4)
  dnl * multi-threaded with data chunk reads (-j4 -x)
  RUN_TEST_EWFTOOL_AND_COMPARE_STDOUT(
