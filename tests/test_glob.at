m4_include([package.m4])
m4_include([test_macros.at])

dnl Sets up glob helper functions.
m4_define([SETUP_GLOB_HELPER_FUNCTIONS],
  [AT_TEST_HELPER_FN(
    [test_glob_chr],
    [value],
    [chr],
    [CHR_VALUE=`expr \( \( $[]1 / 64 \) \* 100 \) + \( \( \( $[]1 % 64 \) / 8 \) \* 10 \) + \( $[]1 % 8 \)`

    printf \\${CHR_VALUE}
    ])

  AT_TEST_HELPER_FN(
    [generate_test_glob_input],
    [first_extension final_extension],
    [Generates test input for a glob test],
    [FIRST_EXTENSION=$[]1
    LAST_EXTENSION=$[]2

    PREFIX=""
    FIRST_LETTER=`echo ${FIRST_EXTENSION} | cut -c 1`
    SECOND_LETTER=`echo ${FIRST_EXTENSION} | cut -c 2`

    if test "${SECOND_LETTER}" = "x"; then
      PREFIX="${FIRST_LETTER}"
      FIRST_LETTER="${SECOND_LETTER}"
    fi
    SECOND_LETTER="0"
    THIRD_LETTER="1"

    if test "${FIRST_LETTER}" = "E"; then
      FIRST_LETTER_BASE=69
      LETTER_BASE=65
    elif test "${FIRST_LETTER}" = "e"; then
      FIRST_LETTER_BASE=101
      LETTER_BASE=97
    elif test "${FIRST_LETTER}" = "L"; then
      FIRST_LETTER_BASE=76
      LETTER_BASE=65
    elif test "${FIRST_LETTER}" = "s"; then
      FIRST_LETTER_BASE=115
      LETTER_BASE=97
    elif test "${FIRST_LETTER}" = "x"; then
      FIRST_LETTER_BASE=120
      LETTER_BASE=65
    fi
    SEGMENT_INDEX=1

    FILENAMES=""

    while true; do
      CURRENT_EXTENSION="${PREFIX}${FIRST_LETTER}${SECOND_LETTER}${THIRD_LETTER}"
      FILENAME="PREFIX.${CURRENT_EXTENSION}"

      if test -n "${FILENAMES}"; then
        FILENAMES="${FILENAMES} ${FILENAME}"
      else
        FILENAMES="${FILENAME}"
      fi
      echo "${FILENAME}" >> expected_output

      if test "${CURRENT_EXTENSION}" = "${LAST_EXTENSION}"; then
        break
      fi
      SEGMENT_INDEX=`expr ${SEGMENT_INDEX} + 1`

      if test ${SEGMENT_INDEX} -lt 100; then
        LOWER_DIGIT=`expr ${SEGMENT_INDEX} % 10`
        UPPER_DIGIT=`expr ${SEGMENT_INDEX} / 10`

        THIRD_LETTER="${LOWER_DIGIT}"
        SECOND_LETTER="${UPPER_DIGIT}"
      else
        LOWER_PART=`expr ${LETTER_BASE} + \( \( ${SEGMENT_INDEX} - 100 \) % 26 \)`
        MIDDLE_PART=`expr ${LETTER_BASE} + \( \( \( ${SEGMENT_INDEX} - 100 \) / 26 \) % 26 \)`
        UPPER_PART=`expr ${FIRST_LETTER_BASE} + \( \( ${SEGMENT_INDEX} - 100 \) / \( 26 \* 26 \) \)`

        THIRD_LETTER=`ath_fn_test_glob_chr ${LOWER_PART}`
        SECOND_LETTER=`ath_fn_test_glob_chr ${MIDDLE_PART}`
        FIRST_LETTER=`ath_fn_test_glob_chr ${UPPER_PART}`
      fi
    done
    touch ${FILENAMES}
    ])

  AT_TEST_HELPER_FN(
    [compare_test_glob_output],
    [],
    [Compares the test output with the expected output],
    [OSTYPE_LOWER=`echo "$OSTYPE" | tr '[A-Z]' '[a-z]'`
    case "${OSTYPE_LOWER}" in
      cygwin*|linux-gnu*|msys*)
        if test "${USE_MINGW}" = "yes" || test "${USE_WINAPI}" = "yes"; then
	  sed -i'~' 's/\r$//' output
        fi
        ;;
    esac

    if ! cmp -s output expected_output; then
      diff expected_output output
      return 1
    fi
    return 0
    ])

  AT_TEST_HELPER_FN(
    [run_test_glob],
    [filenames],
    [Generates test input for a glob test],
    [ath_fn_run_test_binary $[]1 $[]2 > output
    RESULT=$?

    if test ${RESULT} -eq 0; then
      ath_fn_compare_test_glob_output
      RESULT=$?
    fi
    return ${RESULT}
    ])
  ])

dnl Runs a glob test
dnl Arguments:
dnl   first_extension
dnl   final_extension
dnl   glob
m4_define([RUN_TEST_GLOB],
  [m4_define(
    [test_binary],
    [m4_expand(test_prefix[]_test_glob)])dnl

  m4_if(
    [$1],
    [$2],
    [m4_define(
      [test_description],
      [test_binary with 'PREFIX.$1'])],
    [m4_define(
      [test_description],
      [test_binary with 'PREFIX.$1 - PREFIX.$2'])])

  AT_SETUP(test_description)

  AT_SKIP_IF(
    [test -n "${SKIP_LIBRARY_TESTS}"])

  ath_fn_generate_test_glob_input "$1" "$2"

  AT_CHECK([ath_fn_run_test_glob test_binary "PREFIX.$1"])

  AT_CLEANUP])
])

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running glob tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([glob])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS
SETUP_GLOB_HELPER_FUNCTIONS

dnl Test E01 naming schema
RUN_TEST_GLOB(
 [E01],
 [E01])

RUN_TEST_GLOB(
 [E01],
 [E09])

RUN_TEST_GLOB(
