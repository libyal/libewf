dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running tools tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([tools])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS

m4_if(
  HAVE_MULTI_THREAD_SUPPORT,
  [1],
  [dnl Test with:
  dnl * single-threaded with buffered writes (-j0)
  dnl * single-threaded with data chunk writes (-j0 -x)
  dnl * multi-threaded with buffered writes (-j4)
  dnl * multi-threaded with data chunk writes (-j4 -x)
  RUN_WRITE_TEST_EWFACQUIRE(
    [ewfacquire],
    [-j0],
    test_inputs_ewfacquire)

  RUN_WRITE_TEST_EWFACQUIRE(
    [ewfacquire],
    [-j0 -x],
    test_inputs_ewfacquire)

  RUN_WRITE_TEST_EWFACQUIRE(
    [ewfacquire],
    [-j4],
    test_inputs_ewfacquire)

  RUN_WRITE_TEST_EWFACQUIRE(
    [ewfacquire],
    [-j4 -x],
    test_inputs_ewfacquire)],

  [dnl Test with:
  dnl * with buffered writes
  dnl * with data chunk writes (-x)
  RUN_WRITE_TEST_EWFACQUIRE(
